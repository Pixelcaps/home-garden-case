# Copy to .env for local development:  cp .env.example .env
# Nx automatically loads .env for its tasks (nx dev api / nx dev web), so no
# inline environment variables are needed.

# Backend URL the web app's server-side loaders/actions (the BFF) call.
API_BASE_URL=http://localhost:3000

# Shared bearer token. The API's @fastify/bearer-auth gate requires it, and the
# web BFF attaches it server-side. Use the SAME value in both apps, or leave it
# empty in both to run the API ungated.
API_BEARER_TOKEN=dev-secret

# The seeded "implicit user" whose gardens the app shows (see README auth notes).
DEFAULT_USER_ID=1
